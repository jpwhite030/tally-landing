# Copy to `.env.local` for local dev (and set in Vercel for production).

# Optional: where waitlist emails are forwarded. If unset, the API route just
# logs the email server-side so the form still works end-to-end.
# Example: a Formspree endpoint, e.g. https://formspree.io/f/xxxxxxx
WAITLIST_ENDPOINT=

# Public site URL (used for SEO/OG metadata).
NEXT_PUBLIC_SITE_URL=https://tallytax.app
